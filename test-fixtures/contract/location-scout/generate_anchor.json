{
  "meta": {
    "fixture_id": "location-scout.generate_anchor.v1",
    "agent": "location-scout",
    "tool": "generate_anchor",
    "version_added": "v1.0.24",
    "adapted_on_replit": "2026-04-28",
    "regression_guard": "Async write-path tool — kickoff returns `{task_id, status:'accepted'}` and the real artifact arrives only via task polling. Hard-gated on Bible approval_status='approved'; gate failures surface as task `status:'failed'` with FL_ERRORS code in `error`, NOT as a 200 with an `image_id` so a client that 'optimistically' uses image_id from kickoff would mis-fire on rejected gates. The terminal `artifacts[0].uri` MUST follow `agent://location-scout/anchor/{bible_id}` — the trailing-segment is the bible_id (entity_id), not a UUID like ShotGeneration. Validation reports are ALSO emitted in `artifacts` (mime application/json under agent://location-scout/validation/{validation_id}); they are append-only and ordered after the anchor PNG."
  },
  "request_template": {
    "method": "tools/call",
    "params": {
      "name": "generate_anchor",
      "arguments": {
        "bible_uri": "agent://location-scout/bible/<bible_id>",
        "validation": {
          "enabled": true,
          "max_attempts": 3,
          "threshold": 0.75
        },
        "auto_resolve": true
      }
    }
  },
  "async": true,
  "kickoff_response_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["task_id", "status"],
    "properties": {
      "task_id": {
        "type": "string",
        "pattern": "^[0-9a-f-]{32,36}$"
      },
      "status": {
        "type": "string",
        "enum": ["accepted", "submitted", "queued"]
      }
    }
  },
  "poll_contract": {
    "tool": "get_task_status",
    "task_id_from": "$.task_id",
    "args_template": { "task_id": "${task_id}" },
    "interval_sec": 5,
    "max_wait_sec": 300,
    "terminal_success": ["completed", "success", "done"],
    "terminal_failure": ["failed", "error", "cancelled"],
    "status_response_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string" },
        "progress": { "type": "number", "minimum": 0, "maximum": 1 },
        "current_step": { "type": "string" },
        "task_id": { "type": "string" }
      }
    },
    "unknown_task_response_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "const": "unknown" }
      }
    }
  },
  "final_fetch": {
    "tool": "get_task_result",
    "args_template": { "task_id": "${task_id}" }
  },
  "final_response_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["status", "artifacts"],
    "properties": {
      "status": { "const": "completed" },
      "artifacts": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["uri", "mime_type"],
          "properties": {
            "uri": {
              "type": "string",
              "pattern": "^agent://location-scout/(anchor|validation)/[A-Za-z0-9_-]+$"
            },
            "mime_type": {
              "type": "string",
              "enum": ["image/png", "application/json"]
            },
            "created_at": { "type": "string", "format": "date-time" }
          }
        }
      },
      "prompt_used": { "type": "string" },
      "task_id": { "type": "string" }
    }
  },
  "extract_for_chaining": {
    "anchor_uri": "$.artifacts[?(@.mime_type=='image/png')].uri[0]"
  }
}
