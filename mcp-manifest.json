{
  "name": "location-scout-base",
  "version": "1.0.0",
  "description": "Location research, Bible writing, anchor generation, mood states, and spatial planning",
  "transport": {
    "type": "streamable-http",
    "url": "/mcp"
  },
  "capabilities": {
    "tools": true,
    "resources": true,
    "notifications": true
  },
  "authentication": {
    "type": "bearer",
    "description": "GCP Identity Token via Cloud Run IAM"
  },
  "platform": {
    "registry": "Film Language",
    "schema_package": "@filmlanguage/schemas",
    "orchestrator": "1ad-base",
    "scaffold": false
  },
  "dependencies": [
    "agent://1ad/film-ir/{project_id}",
    "agent://director/vision/dfv/{project_id}"
  ]
}
