# LocationScout-Base — environment variables
# Copy this file: cp .env.example .env
# Then fill in your keys.

# === LLM (Claude / Anthropic) ===
ANTHROPIC_API_KEY=
# Claude model ID — default is claude-sonnet-4-6. Override to use a different model.
LLM_MODEL=claude-sonnet-4-6

# === Image generation + Gemini Vision (FAL.ai) ===
# Single FAL key — used for image generation and Gemini Vision (via FAL binding)
FAL_AI_API_KEY=

# Per-slot model overrides. Each slot is resolved in this order:
#   1. `model` passed as tool arg (runtime override)
#   2. FAL_MODEL_<SLOT> env var (per-slot default)
#   3. FAL_MODEL_DEFAULT env var (agent-wide default)
#   4. Built-in default: nano-banana/edit
#
# Known logical names (see src/lib/model-registry.ts for full list):
#   nano-banana         — fal-ai/nano-banana         (text->image)
#   nano-banana/edit    — fal-ai/nano-banana/edit    (image->image, holds composition)
#   flux-pro            — fal-ai/flux-pro/v1.1       (highest quality)
#   flux-dev            — fal-ai/flux/dev            (balanced)
#   flux-schnell        — fal-ai/flux/schnell        (fastest, cheapest)
#
# You can also put a full endpoint path here (e.g. "fal-ai/some-model/v2") and it
# will be passed through verbatim.

FAL_MODEL_DEFAULT=nano-banana/edit
FAL_MODEL_ANCHOR=nano-banana/edit
FAL_MODEL_MOOD_VARIANT=nano-banana/edit
FAL_MODEL_ISOMETRIC=nano-banana/edit

# === S3-Compatible Storage (GCS S3 interop) ===
S3_BUCKET=fl-location-scout-artifacts
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://storage.googleapis.com

# === Local storage ===
# If set, artifacts and images are also written to this directory on disk.
# Useful for local dev — Claude Code can then Read the generated PNGs directly.
LOCAL_OUTPUT_DIR=./output

# === Inter-agent auth ===
# Shared token for agent-to-agent HTTP calls. Empty = no auth (dev mode).
INTER_AGENT_TOKEN=1234

# === Upstream agent URLs (Phase 3b MCP auto-resolve) ===
# Used by scout_location, research_era, write_bible to auto-fetch location_brief
# and director_vision when called with project_id only.
AGENT_1AD_URL=http://localhost:8081
AGENT_DIRECTOR_URL=http://localhost:8082

# === Python (for floorplan generation) ===
# Binary name — usually "python" on Windows, "python3" on Linux/mac.
PYTHON_BIN=python

# === Server ===
PORT=8083

# === Yandex Managed PostgreSQL (v2 pipeline storage) ===
# When all YANDEX_DB_* are set, artifacts are mirrored to schema `v2` in addition
# to local disk / S3. Leave blank in dev to skip DB mirror.
# CA cert path is optional — defaults to ~/.postgresql/root.crt.
YANDEX_DB_HOST=
YANDEX_DB_PORT=6432
YANDEX_DB_NAME=filmlanguage
YANDEX_DB_USER=
YANDEX_DB_PASSWORD=
YANDEX_DB_CA_CERT=

# Project key stamped on every artifact when the payload doesn't include
# a project_id. Used to group shadow v2.projects rows.
LS_DEFAULT_PROJECT_KEY=default-project
