# LocationScout-Base — environment variables
# Copy this file: cp .env.example .env
# Then fill in your keys.

ANTHROPIC_API_KEY=
FAL_AI_API_KEY=

# Google Cloud Storage (optional — falls back to in-memory store for local dev)
GCS_BUCKET=
PROJECT_ID=

# LLM model override (default: claude-sonnet-4-6)
# LLM_MODEL=claude-sonnet-4-6
