{
  "name": "fl-location-scout-base",
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "check-env": "bash check-env.sh",
    "inspect": "npx @modelcontextprotocol/inspector",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:ui": "vite",
    "build:ui": "tsc -p tsconfig.ui.json",
    "build:all": "npm run build && npm run build:ui",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ui\""
  },
  "dependencies": {
    "@filmlanguage/schemas": "file:./_schemas",
    "@filmlanguage/tokens": "file:./_tokens",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.1",
    "express": "^4.21.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^6.0.1",
    "glob": "^13.0.6",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.5",
    "vitest": "^3.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.0"
  }
}
